{
    "name": "firevel/firebase-authentication",
    "description": "Firebase authentication driver for Laravel",
    "type": "library",
    "keywords": [
        "laravel",
        "firebase",
        "authentication",
        "jwt",
        "firevel",
        "auth"
    ],
    "homepage": "https://github.com/firevel/firebase-authentication",
    "require": {
        "php": "^8.2",
        "illuminate/auth": "^11.0|^12.0|^13.0",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "illuminate/routing": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "kreait/firebase-tokens": "^5.0",
        "psr/cache": "^3.0",
        "symfony/cache": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "mockery/mockery": "^1.6",
        "laravel/pint": "^1.0"
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Firevel\\FirebaseAuthentication\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Firevel\\FirebaseAuthentication\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage",
        "format": "vendor/bin/pint",
        "check-style": "vendor/bin/pint --test"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Firevel\\FirebaseAuthentication\\FirebaseAuthenticationServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "authors": [
        {
            "name": "Michael Slowik",
            "email": "michael.slowik@firevel.com"
        }
    ]
}
